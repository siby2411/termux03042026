<?php
session_start();
require_once '../../config/database.php';
require_once '../../includes/auth.php';

if (!isset($_SESSION['user_id']) || $_SESSION['user_role'] !== 'admin') {
    header('Location: /login.php');
    exit();
}

$pdo = getPDO();

// Statistiques globales
$stats = $pdo->query("
    SELECT 
        (SELECT COUNT(*) FROM patients) as patients,
        (SELECT COUNT(*) FROM consultations) as consultations,
        (SELECT COUNT(*) FROM rendez_vous WHERE date_rdv >= CURDATE()) as rdv,
        (SELECT COUNT(*) FROM paiements) as paiements,
        (SELECT SUM(montant_total) FROM paiements) as recettes,
        (SELECT COUNT(*) FROM users WHERE role = 'medecin') as medecins,
        (SELECT COUNT(*) FROM users WHERE role = 'caissier') as caissiers,
        (SELECT COUNT(*) FROM services) as services,
        (SELECT COUNT(*) FROM materiel) as equipements,
        (SELECT COUNT(*) FROM file_attente WHERE statut = 'en_attente') as file_attente,
        (SELECT COUNT(*) FROM salles) as salles,
        (SELECT COUNT(*) FROM batiments) as batiments
")->fetch();

// Statistiques par service pour la file d'attente
$file_attente_services = $pdo->query("
    SELECT s.name, COUNT(f.id) as total
    FROM file_attente f
    RIGHT JOIN services s ON f.service_id = s.id AND f.statut = 'en_attente'
    GROUP BY s.id, s.name
    ORDER BY total DESC
")->fetchAll();

// Derniers équipements ajoutés
$derniers_equipements = $pdo->query("
    SELECT m.*, s.name as service_nom, cat.nom as categorie_nom
    FROM materiel m
    LEFT JOIN services s ON m.service_id = s.id
    LEFT JOIN categories_materiel cat ON m.categorie_id = cat.id
    ORDER BY m.id DESC
    LIMIT 5
")->fetchAll();

// Dernières activités
$recent_activities = $pdo->query("
    (SELECT 'patient' as type, CONCAT(prenom, ' ', nom) as libelle, created_at 
     FROM patients ORDER BY created_at DESC LIMIT 3)
    UNION ALL
    (SELECT 'paiement' as type, CONCAT('Facture ', numero_facture, ' - ', montant_total, ' FCFA') as libelle, date_paiement as created_at 
     FROM paiements ORDER BY date_paiement DESC LIMIT 3)
    UNION ALL
    (SELECT 'materiel' as type, CONCAT('Nouveau: ', nom) as libelle, created_at 
     FROM materiel ORDER BY created_at DESC LIMIT 3)
    UNION ALL
    (SELECT 'rdv' as type, CONCAT('RDV #', id) as libelle, cree_le as created_at 
     FROM rendez_vous ORDER BY cree_le DESC LIMIT 3)
    ORDER BY created_at DESC LIMIT 8
")->fetchAll();
?>
