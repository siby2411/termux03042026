<?php
session_start();
require_once '../../config/database.php';
require_once '../../includes/auth.php';

if (!isset($_SESSION['user_id']) || $_SESSION['user_role'] !== 'caissier') {
    header('Location: /login.php');
    exit();
}

$pdo = getPDO();
$message = '';
$error = '';
$token_info = null;
$selected_patient = null;

// Récupérer tous les départements/services avec leurs informations complètes
$departements = $pdo->query("
    SELECT DISTINCT 
        s.id, 
        s.name, 
        s.prix_consultation,
        b.nom as batiment_nom,
        n.nom as niveau_nom,
        za.nom as zone_attente,
        sa.numero_salle,
        sa.instructions_acces,
        sa.code_couleur,
        COUNT(DISTINCT sa.id) as nb_salles,
        (SELECT COUNT(*) FROM file_attente WHERE service_id = s.id AND statut = 'en_attente') as en_attente
    FROM services s
    JOIN salles sa ON s.id = sa.service_id
    JOIN batiments b ON sa.batiment_id = b.id
    JOIN niveaux n ON sa.niveau_id = n.id
    JOIN zones_attente za ON sa.zone_attente_id = za.id
    WHERE s.name NOT IN ('Caisse', 'Accueil/Triage')
    GROUP BY s.id
    ORDER BY s.name
")->fetchAll();

// Statistiques des consultations par département aujourd'hui
$stats_dept = $pdo->query("
    SELECT 
        s.name as departement,
        COUNT(c.id) as nb_consultations,
        COALESCE(SUM(ca.prix_applique), 0) as total_recettes
    FROM services s
    LEFT JOIN consultations c ON s.id = c.service_id AND DATE(c.date_consultation) = CURDATE()
    LEFT JOIN consultation_actes ca ON c.id = ca.consultation_id
    WHERE s.name NOT IN ('Caisse', 'Accueil/Triage')
    GROUP BY s.id
    ORDER BY nb_consultations DESC
")->fetchAll();

// Recherche de patient
if (isset($_GET['search'])) {
    $search = '%' . $_GET['search'] . '%';
    $stmt = $pdo->prepare("
        SELECT * FROM patients 
        WHERE prenom LIKE ? OR nom LIKE ? OR telephone LIKE ? OR numero_patient LIKE ?
        ORDER BY created_at DESC
    ");
    $stmt->execute([$search, $search, $search, $search]);
    $search_result = $stmt->fetchAll();
}

// Si un patient est sélectionné
if (isset($_GET['patient_id'])) {
    $stmt = $pdo->prepare("SELECT * FROM patients WHERE id = ?");
    $stmt->execute([$_GET['patient_id']]);
    $selected_patient = $stmt->fetch();
}

// Enregistrement nouveau patient
if ($_SERVER['REQUEST_METHOD'] === 'POST' && isset($_POST['new_patient'])) {
    $numero = 'PAT-' . date('Ymd') . '-' . str_pad(rand(1, 9999), 4, '0', STR_PAD_LEFT);
    
    try {
        $pdo->beginTransaction();
        
        $stmt = $pdo->prepare("
            INSERT INTO patients (numero_patient, prenom, nom, date_naissance, sexe, telephone, adresse) 
            VALUES (?, ?, ?, ?, ?, ?, ?)
        ");
        $stmt->execute([
            $numero,
            $_POST['prenom'],
            $_POST['nom'],
            $_POST['date_naissance'],
            $_POST['sexe'],
            $_POST['telephone'],
            $_POST['adresse'] ?? null
        ]);
        $patient_id = $pdo->lastInsertId();
        
        // Créer le dossier médical
        $pdo->prepare("INSERT INTO dossiers_medicaux (patient_id) VALUES (?)")->execute([$patient_id]);
        
        $pdo->commit();
        
        // Rediriger vers le même patient sélectionné
        header("Location: index.php?patient_id=$patient_id");
        exit();
        
    } catch (Exception $e) {
        $pdo->rollBack();
        $error = "Erreur: " . $e->getMessage();
    }
}

// Génération de token et paiement automatique
if ($_SERVER['REQUEST_METHOD'] === 'POST' && isset($_POST['generate_token'])) {
    try {
        $pdo->beginTransaction();
        
        $patient_id = $_POST['patient_id'];
        $service_id = $_POST['service_id'];
        $mode_paiement = $_POST['mode_paiement'];
        
        // Récupérer les informations du patient
        $stmt = $pdo->prepare("SELECT prenom, nom, date_naissance FROM patients WHERE id = ?");
        $stmt->execute([$patient_id]);
        $patient = $stmt->fetch();
        
        // Calculer la priorité (senior si âge > 60)
        $age = date('Y') - date('Y', strtotime($patient['date_naissance']));
        $priorite = ($age >= 60) ? 'senior' : 'normal';
        
        // Récupérer les informations du service et de la salle
        $stmt = $pdo->prepare("
            SELECT 
                s.id as service_id,
                s.name as service_nom,
                s.prix_consultation,
                sa.numero_salle,
                b.nom as batiment_nom,
                n.nom as niveau_nom,
                za.nom as zone_attente,
                sa.instructions_acces
            FROM services s
            JOIN salles sa ON s.id = sa.service_id
            JOIN batiments b ON sa.batiment_id = b.id
            JOIN niveaux n ON sa.niveau_id = n.id
            JOIN zones_attente za ON sa.zone_attente_id = za.id
            WHERE s.id = ?
            LIMIT 1
        ");
        $stmt->execute([$service_id]);
        $service_info = $stmt->fetch();
        
        // Générer token unique
        $token = 'TKN' . date('His') . str_pad(rand(1, 999), 3, '0', STR_PAD_LEFT);
        
        // Insérer dans file_attente
        $stmt = $pdo->prepare("
            INSERT INTO file_attente (
                token, patient_id, service_id, departement, priorite, 
                salle, salle_numero, etage, batiment_nom, niveau_nom, 
                zone_attente, instructions, statut, cree_a
            ) VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, 'en_attente', NOW())
        ");
        $stmt->execute([
            $token,
            $patient_id,
            $service_id,
            $service_info['service_nom'],
            $priorite,
            $service_info['numero_salle'],
            $service_info['numero_salle'],
            $service_info['niveau_nom'],
            $service_info['batiment_nom'],
            $service_info['niveau_nom'],
            $service_info['zone_attente'],
            $service_info['instructions_acces']
        ]);
        
        $file_id = $pdo->lastInsertId();
        
        // Créer la facture automatiquement avec le prix du service
        $numero_facture = 'FACT-' . date('Ymd') . '-' . str_pad($file_id, 4, '0', STR_PAD_LEFT);
        
        $stmt = $pdo->prepare("
            INSERT INTO paiements (
                numero_facture, patient_id, caissier_id, 
                montant_total, montant_paye, mode_paiement, statut
            ) VALUES (?, ?, ?, ?, ?, ?, 'paye')
        ");
        $stmt->execute([
            $numero_facture,
            $patient_id,
            $_SESSION['user_id'],
            $service_info['prix_consultation'],
            $service_info['prix_consultation'], // Paiement automatique du montant total
            $mode_paiement
        ]);
        
        $pdo->commit();
        
        // Préparer les informations pour l'affichage du ticket
        $token_info = [
            'token' => $token,
            'patient' => $patient['prenom'] . ' ' . $patient['nom'],
            'service' => $service_info['service_nom'],
            'prix' => $service_info['prix_consultation'],
            'priorite' => $priorite,
            'age' => $age,
            'salle' => $service_info['numero_salle'],
            'batiment' => $service_info['batiment_nom'],
            'niveau' => $service_info['niveau_nom'],
            'zone' => $service_info['zone_attente'],
            'instructions' => $service_info['instructions_acces'],
            'date' => date('d/m/Y'),
            'heure' => date('H:i'),
            'facture' => $numero_facture,
            'mode' => $mode_paiement
        ];
        
        $message = "✅ Patient enregistré, paiement automatique de " . number_format($service_info['prix_consultation'], 0, ',', ' ') . " FCFA effectué !";
        
    } catch (Exception $e) {
        $pdo->rollBack();
        $error = "❌ Erreur: " . $e->getMessage();
    }
}

// Récupérer la file d'attente
$queue = $pdo->query("
    SELECT f.*, p.prenom, p.nom
    FROM file_attente f
    JOIN patients p ON f.patient_id = p.id
    WHERE f.statut = 'en_attente'
    ORDER BY FIELD(f.priorite, 'urgence', 'senior', 'normal'), f.cree_a ASC
    LIMIT 20
")->fetchAll();

// Récupérer les états de caisse
$caissier_stats = $pdo->prepare("
    SELECT 
        COUNT(*) as total_paiements,
        SUM(montant_total) as total_recettes,
        DATE(date_paiement) as jour
    FROM paiements
    WHERE caissier_id = ? AND DATE(date_paiement) = CURDATE()
    GROUP BY DATE(date_paiement)
");
$caissier_stats->execute([$_SESSION['user_id']]);
$stats = $caissier_stats->fetch();

$derniers_paiements = $pdo->prepare("
    SELECT p.*, pat.prenom, pat.nom
    FROM paiements p
    JOIN patients pat ON p.patient_id = pat.id
    WHERE p.caissier_id = ?
    ORDER BY p.date_paiement DESC
    LIMIT 5
");
$derniers_paiements->execute([$_SESSION['user_id']]);
$recent_payments = $derniers_paiements->fetchAll();
?>
