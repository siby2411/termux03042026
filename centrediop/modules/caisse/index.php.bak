    <script>
    function updateServiceInfo(select) {
        const selected = select.options[select.selectedIndex];
        const prix = selected.dataset.prix || 0;
        const batiment = selected.dataset.batiment || '';
        const niveau = selected.dataset.niveau || '';
        const salle = selected.dataset.salle || '';
        const zone = selected.dataset.zone || '';
        const attente = selected.dataset.attente || 0;
        
        // Mettre à jour l'affichage du montant
        document.getElementById('montant_affichage').innerHTML = new Intl.NumberFormat('fr-FR').format(prix) + ' FCFA';
        
        if (batiment) {
            document.getElementById('infoBatiment').innerHTML = '<i class="fas fa-building me-2"></i> Bâtiment: ' + batiment;
            document.getElementById('infoNiveau').innerHTML = '<i class="fas fa-layer-group me-2"></i> Niveau: ' + niveau;
            document.getElementById('infoSalle').innerHTML = '<i class="fas fa-door-open me-2"></i> Salle: ' + salle;
            document.getElementById('infoZone').innerHTML = '<i class="fas fa-chair me-2"></i> Zone: ' + zone;
            document.getElementById('infoAttente').innerHTML = '<i class="fas fa-clock me-2"></i> Patients en attente: ' + attente;
            
            document.getElementById('serviceInfo').style.display = 'block';
        } else {
            document.getElementById('serviceInfo').style.display = 'none';
            document.getElementById('montant_affichage').innerHTML = '0 FCFA';
        }
    }
    
    // Actualisation automatique toutes les 30 secondes
    <?php if (!$token_info): ?>
    setTimeout(() => location.reload(), 30000);
    <?php endif; ?>
    </script>
    
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
