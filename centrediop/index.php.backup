<?php
session_start();
require_once 'config/database.php';
require_once 'includes/auth.php';
require_once 'includes/functions.php';

// Redirection si déjà connecté
if (isset($_SESSION['user_id'])) {
    switch ($_SESSION['user_role']) {
        case 'admin': header('Location: modules/admin/dashboard.php'); break;
        case 'caissier': header('Location: modules/caisse/index.php'); break;
        case 'sagefemme': header('Location: modules/sagefemme/index.php'); break;
        case 'medecin': header('Location: modules/medecin/consultation.php'); break;
        default: header('Location: modules/dashboard/index.php');
    }
    exit();
}

$pdo = getPDO();

// Statistiques globales pour la page d'accueil
$stats = $pdo->query("
    SELECT 
        (SELECT COUNT(*) FROM patients) as total_patients,
        (SELECT COUNT(*) FROM users WHERE role = 'medecin') as total_medecins,
        (SELECT COUNT(*) FROM services) as total_services,
        (SELECT COUNT(*) FROM file_attente WHERE statut = 'en_attente') as en_attente
")->fetch();
?>
