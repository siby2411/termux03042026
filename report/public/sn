<div class="card">
    <h3 class="text-center mb-4">Liste des Immobilisations</h3>

    <?php if (empty($immobilisations)): ?>
        <div class="alert alert-warning">Aucune immobilisation trouvée.</div>
    <?php else: ?>
        <table class="table table-bordered table-striped">
            <thead class="table-dark">
                <tr>
                    <th>ID</th>
                    <th>Société</th>
                    <th>Intitulé</th>
                    <th>Valeur</th>
                    <th>Date acquisition</th>
                    <th>Mode amortissement</th>
                    <th>Taux (%)</th>
                </tr>
            </thead>
            <tbody>
                <?php foreach ($immobilisations as $i): ?>
                    <tr>
                        <td><?= htmlspecialchars($i['immo_id']) ?></td>
                        <td><?= htmlspecialchars($i['nom_societe'] ?? '-') ?></td>
                        <td><?= htmlspecialchars($i['designation']) ?></td>
                        <td><?= number_format($i['valeur_origine'], 2, '.', ' ') ?></td>
                        <td><?= htmlspecialchars($i['date_acquisition']) ?></td>
                        <td><?= htmlspecialchars($i['mode_amort']) ?></td>
                        <td><?= htmlspecialchars($i['taux']) ?></td>
                    </tr>
                <?php endforeach; ?>
            </tbody>
        </table>
    <?php endif; ?>
