<?php
session_start();
require __DIR__ . '/../config/config.php'; // chemin correct vers config.php

// Récupération des immobilisations avec la société associée
try {
    $stmt = $pdo->query("
        SELECT i.immo_id, s.nom_societe, i.designation, i.valeur_origine, i.date_acquisition, i.mode_amort, i.taux
        FROM IMMOBILISATIONS i
        LEFT JOIN SOCIETES s ON i.societe_id = s.societe_id
        ORDER BY i.immo_id DESC
    ");
    $immobilisations = $stmt->fetchAll(PDO::FETCH_ASSOC);
} catch (PDOException $e) {
    die("Erreur récupération immobilisations : " . $e->getMessage());
}
?>

