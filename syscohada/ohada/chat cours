Le script doit vérifier si l'intitulé existe déjà auquel cas on annule l'insertion dans le cas contraire on valide l'insertion

<?php
// Connexion à la base de données PostgreSQL
$host = 'localhost';
$dbname = 'ohada';
$user = 'root';
$password = '123';

try {
    $pdo = new PDO("mysql:host=$host;dbname=$dbname", $user, $password);
    $pdo->setAttribute(PDO::ATTR_ERRMODE, PDO::ERRMODE_EXCEPTION);

    // Vérification que le formulaire a été soumis
    if ($_SERVER["REQUEST_METHOD"] == "POST") {
        // Récupérer les données du formulaire
        $intitule = $_POST['intitule'];
        $cours = $_POST['cours'];

        // Préparer et exécuter la requête d'insertion
        $sql = "INSERT INTO cours (intitulé, cours) VALUES (:intitule, :cours)";
        $stmt = $pdo->prepare($sql);
        $stmt->bindParam(':intitule', $intitule);
        $stmt->bindParam(':cours', $cours);

        if ($stmt->execute()) {
            echo "Cours ajouté avec succès !";
        } else {
            echo "Erreur lors de l'ajout du cours.";
        }
    }
} catch (PDOException $e) {
    echo "Erreur : " . $e->getMessage();
}
?>